{
  "id": "wechat",
  "name": "WeChat",
  "description": "WeChat message channel plugin for OpenClaw",
  "version": "2026.2.17",
  "author": "OpenClaw Team",
  "type": "channel",
  "main": "index.ts",
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Enable WeChat channel"
    },
    "puppet": {
      "type": "string",
      "default": "wechat4u",
      "description": "WeChat puppet type"
    },
    "autoAuth": {
      "type": "boolean",
      "default": false,
      "description": "Auto authenticate on startup"
    },
    "enableCommands": {
      "type": "boolean",
      "default": true,
      "description": "Enable commands"
    },
    "commandPrefix": {
      "type": "string",
      "default": "/",
      "description": "Command prefix"
    },
    "allowedUsers": {
      "type": "array",
      "default": [],
      "description": "Allowed user IDs"
    },
    "allowedRooms": {
      "type": "array",
      "default": [],
      "description": "Allowed room IDs"
    },
    "messageDelay": {
      "type": "number",
      "default": 1000,
      "description": "Message delay in milliseconds"
    },
    "maxMessages": {
      "type": "number",
      "default": 100,
      "description": "Max messages to store"
    },
    "webhookUrl": {
      "type": "string",
      "default": "",
      "description": "Webhook URL"
    },
    "webhookEvents": {
      "type": "array",
      "default": [],
      "description": "Webhook events to send"
    }
  },
  "capabilities": [
    "sendMessages",
    "receiveMessages",
    "sendFiles",
    "receiveFiles",
    "sendRichMessages",
    "receiveRichMessages",
    "userManagement",
    "channelManagement"
  ],
  "dependencies": {
    "wechaty": "^1.20.0",
    "wechaty-puppet-wechat4u": "^1.18.0",
    "qrcode-terminal": "^0.12.0"
  }
}
